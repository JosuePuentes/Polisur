{
  "name": "@polisur/database",
  "version": "0.1.0",
  "description": "Capa de datos Polisur: Prisma, módulo NestJS y DTOs compartidos",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dto": {
      "types": "./dist/dto/index.d.ts",
      "require": "./dist/dto/index.js",
      "import": "./dist/dto/index.js"
    }
  },
  "files": [
    "dist",
    "prisma",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "generate": "prisma generate --schema=./prisma/schema.prisma",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "prisma": "^6.9.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.21",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
