// Polisur — Esquema relacional definitivo (PostgreSQL + Prisma)
// Organigrama descentralizado · Evidencias tácticas · RBAC · Patrullaje

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum RangeRole {
  SUPER_ADMIN
  JEFE_DEPARTAMENTO
  OFICIAL_ACTIVO
  DISCENTE
}

enum IncidentStatus {
  PENDIENTE
  DESPACHADO
  EN_TRANSITO
  PENDIENTE_RESEÑA
  PROCESADO
  CERRADO
}

enum EvidenceStage {
  RETORNO_CALLE
  RESEÑA_COMANDO
}

enum IncidentOrigin {
  INTERNO
  PUBLICO_ANONIMO
  PUBLICO_PANICO
}

enum AuditActionKind {
  HTTP_REQUEST
  CRITICAL_ACTION
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ShiftStatus {
  OFF_DUTY
  ON_DUTY_PENDING
  ON_DUTY_ACTIVE
}

enum AssetType {
  PATRULLA
  MOTO
  EQUIPO
  RADIO
  OTRO
}

enum AssetStatus {
  OPERATIVO
  MANTENIMIENTO
  BAJA
}

enum WeaponStatus {
  DISPONIBLE
  ASIGNADA
  MANTENIMIENTO
  BAJA
}

enum DetaineeStatus {
  EN_CALABOZO
  AUDIENCIA
  TRASLADADO_FISCALIA
  LIBERADO
}

enum PatrolType {
  PATRULLAJE
  MINUTA
  PROCEDIMIENTO_MIXTO
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANIGRAMA
// ─────────────────────────────────────────────────────────────────────────────

/// Direcciones o comandos locales administrables (Antidrogas, Violencia de Género, etc.)
model Department {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(32)
  name        String   @db.VarChar(120)
  description String?  @db.Text
  address     String?  @db.VarChar(200)
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  commanderId String?
  commander   Officer? @relation("DepartmentCommander", fields: [commanderId], references: [id], onDelete: SetNull)

  squads           Squad[]
  officers         Officer[]         @relation("OfficerDepartment")
  incidents        Incident[]
  controlPoints    ControlPoint[]
  patrolMinutes    PatrolMinute[]
  inventoryAssets  InventoryAsset[]
  weapons          Weapon[]
  officerShifts    OfficerShift[]

  @@index([isActive], map: "idx_department_active_btree")
  @@index([name], map: "idx_department_name_btree")
  @@map("departments")
}

/// Escuadra táctica creada por el jefe del comando local
model Squad {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(80)
  callsign     String?  @db.VarChar(24)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  /// Jefe de escuadra (relación 1:1 opcional)
  leaderId String?  @unique
  leader   Officer? @relation("SquadLeader", fields: [leaderId], references: [id], onDelete: SetNull)

  members       Officer[]      @relation("SquadMembers")
  incidents     Incident[]
  patrolMinutes PatrolMinute[]

  @@index([departmentId], map: "idx_squad_department_btree")
  @@index([isActive], map: "idx_squad_active_btree")
  @@index([name], map: "idx_squad_name_btree")
  @@map("squads")
}

/// Funcionario: RRHH, control táctico y credencial QR en calle
model Officer {
  id               String    @id @default(cuid())
  cedula           String    @unique @db.VarChar(20)
  nombres          String    @db.VarChar(80)
  apellidos        String    @db.VarChar(80)
  rangeRole        RangeRole @default(OFICIAL_ACTIVO)
  passwordHash     String?   @db.VarChar(255)
  credentialNumber String    @unique @db.VarChar(32)
  qrToken          String    @unique @default(cuid()) @db.VarChar(64)
  telefono         String?   @db.VarChar(20)
  email            String?   @db.VarChar(120)
  fechaNacimiento  DateTime? @db.Date
  direccion        String?   @db.VarChar(200)
  grado            String?   @db.VarChar(60)
  fechaIngreso     DateTime? @db.Date
  permissions      String[]  @default([])
  isSuspended      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  /// Asignación macro por RRHH
  departmentId String
  department   Department @relation("OfficerDepartment", fields: [departmentId], references: [id], onDelete: Restrict)

  commandedDepartments Department[] @relation("DepartmentCommander")

  /// Asignación táctica local por jefe de comando (miembro de escuadra)
  squadId String?
  squad   Squad?  @relation("SquadMembers", fields: [squadId], references: [id], onDelete: SetNull)

  /// Escuadra que lidera (máximo una)
  ledSquad Squad? @relation("SquadLeader")

  /// Cohorte académica (solo aplica cuando rangeRole = DISCENTE)
  promocionId String?
  promocion   Promocion? @relation(fields: [promocionId], references: [id], onDelete: SetNull)

  @@index([cedula], map: "idx_officer_cedula_btree")
  @@index([rangeRole], map: "idx_officer_range_role_btree")
  @@index([departmentId], map: "idx_officer_department_btree")
  @@index([squadId], map: "idx_officer_squad_btree")
  @@index([promocionId], map: "idx_officer_promocion_btree")
  @@index([isSuspended], map: "idx_officer_suspended_btree")
  @@index([apellidos, nombres], map: "idx_officer_name_btree")

  auditLogs            AuditLog[]
  patrolParticipations PatrolMinuteOfficer[]
  createdPatrols       PatrolMinute[]        @relation("PatrolCreator")
  shifts               OfficerShift[]
  weaponAssignments    WeaponAssignment[]    @relation("WeaponAssignee")
  assignedWeapons      WeaponAssignment[]    @relation("WeaponAssigner")
  assignedInventory    InventoryAsset[]      @relation("InventoryAssignee")
  detaineeRecords      DetaineeRecord[]

  @@map("officers")
}

/// Cohorte de la academia policial vinculada a discentes
model Promocion {
  id               String   @id @default(cuid())
  nombreCurso      String   @db.VarChar(120)
  fechaInicio      DateTime @db.Date
  fechaFinEstimada DateTime @db.Date
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  discentes Officer[]

  @@index([fechaInicio], map: "idx_promocion_inicio_btree")
  @@index([fechaFinEstimada], map: "idx_promocion_fin_btree")
  @@index([nombreCurso], map: "idx_promocion_nombre_btree")
  @@map("promociones")
}

// ─────────────────────────────────────────────────────────────────────────────
// OPERACIONES TÁCTICAS Y PATRULLAJE
// ─────────────────────────────────────────────────────────────────────────────

/// Caso, denuncia pública o minuta de patrullaje
model Incident {
  id          String         @id @default(cuid())
  code        String         @unique @db.VarChar(24)
  tipoDelito  String         @db.VarChar(120)
  status      IncidentStatus @default(PENDIENTE)
  parroquia   String         @db.VarChar(80)
  cuadrante   String         @db.VarChar(40)
  descripcion String         @db.Text
  latitude    Float?
  longitude   Float?
  origen      IncidentOrigin @default(INTERNO)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  closedAt    DateTime?

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  /// Comisión actuante exclusiva (responsabilidad legal en calle)
  squadId String
  squad   Squad  @relation(fields: [squadId], references: [id], onDelete: Restrict)

  evidence IncidentEvidence[]
  detaineeRecords DetaineeRecord[]

  @@index([code], map: "idx_incident_code_btree")
  @@index([status], map: "idx_incident_status_btree")
  @@index([cuadrante], map: "idx_incident_cuadrante_btree")
  @@index([parroquia], map: "idx_incident_parroquia_btree")
  @@index([departmentId], map: "idx_incident_department_btree")
  @@index([squadId], map: "idx_incident_squad_btree")
  @@index([tipoDelito], map: "idx_incident_tipo_delito_btree")
  @@index([status, cuadrante], map: "idx_incident_status_cuadrante_btree")
  @@index([departmentId, status], map: "idx_incident_dept_status_btree")
  @@index([createdAt], map: "idx_incident_created_btree")
  @@index([origen], map: "idx_incident_origen_btree")
  @@map("incidents")
}

/// Registro inmutable de evidencia fotográfica en la nube
model IncidentEvidence {
  id          String        @id @default(cuid())
  imageUrl    String        @db.VarChar(2048)
  stage       EvidenceStage
  descripcion String?       @db.VarChar(500)
  capturedAt  DateTime      @default(now())

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Restrict)

  @@index([incidentId], map: "idx_evidence_incident_btree")
  @@index([stage], map: "idx_evidence_stage_btree")
  @@index([incidentId, stage], map: "idx_evidence_incident_stage_btree")
  @@index([capturedAt], map: "idx_evidence_captured_btree")
  @@map("incident_evidence")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDITORÍA FORENSE INMUTABLE (NO-REPUDIO)
// ─────────────────────────────────────────────────────────────────────────────

/// Traza forense append-only: cada registro es inmutable tras la inserción
model AuditLog {
  id           String          @id @default(cuid())
  traceId      String          @db.VarChar(36)
  actionKind   AuditActionKind @default(HTTP_REQUEST)
  severity     AuditSeverity   @default(INFO)
  actionLabel  String?         @db.VarChar(120)
  officerId    String?
  rangeRole    RangeRole?
  clientIp     String          @db.VarChar(45)
  httpMethod   String          @db.VarChar(10)
  endpointUrl  String          @db.VarChar(512)
  routeParams  Json?
  queryParams  Json?
  requestBody  Json?
  statusCode   Int
  success      Boolean
  durationMs   Int?
  metadata     Json?
  errorMessage String?         @db.VarChar(500)
  createdAt    DateTime        @default(now())

  officer Officer? @relation(fields: [officerId], references: [id], onDelete: SetNull)

  @@index([officerId], map: "idx_audit_officer_btree")
  @@index([createdAt], map: "idx_audit_created_btree")
  @@index([endpointUrl], map: "idx_audit_endpoint_btree")
  @@index([actionKind], map: "idx_audit_action_kind_btree")
  @@index([severity], map: "idx_audit_severity_btree")
  @@index([success], map: "idx_audit_success_btree")
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMANDOS, CUADRANTES Y PUNTOS DE CONTROL
// ─────────────────────────────────────────────────────────────────────────────

model ControlPoint {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(120)
  address      String?  @db.VarChar(200)
  latitude     Float?
  longitude    Float?
  pointType    String   @default("PUESTO") @db.VarChar(40)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@index([departmentId], map: "idx_control_point_dept_btree")
  @@map("control_points")
}

model PeaceQuadrant {
  id           String   @id @default(cuid())
  code         String   @unique @db.VarChar(24)
  name         String   @db.VarChar(80)
  parroquia    String   @db.VarChar(80)
  centerLat    Float?
  centerLng    Float?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([parroquia], map: "idx_peace_quadrant_parroquia_btree")
  @@map("peace_quadrants")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATRULLAJE, MINUTAS Y OBJETOS RECUPERADOS
// ─────────────────────────────────────────────────────────────────────────────

model PatrolMinute {
  id           String     @id @default(cuid())
  code         String     @unique @db.VarChar(24)
  patrolType   PatrolType @default(MINUTA)
  parroquia    String     @db.VarChar(80)
  cuadrante    String     @db.VarChar(40)
  descripcion  String     @db.Text
  latitude     Float?
  longitude    Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  squadId String?
  squad   Squad?  @relation(fields: [squadId], references: [id], onDelete: SetNull)

  createdByOfficerId String
  createdByOfficer   Officer @relation("PatrolCreator", fields: [createdByOfficerId], references: [id], onDelete: Restrict)

  incidentId String? @unique

  officers         PatrolMinuteOfficer[]
  recoveredObjects RecoveredObject[]

  @@index([departmentId], map: "idx_patrol_dept_btree")
  @@index([createdAt], map: "idx_patrol_created_btree")
  @@map("patrol_minutes")
}

model PatrolMinuteOfficer {
  id             String  @id @default(cuid())
  isSquadLeader   Boolean @default(false)
  externalSquad  Boolean @default(false)

  patrolMinuteId String
  patrolMinute   PatrolMinute @relation(fields: [patrolMinuteId], references: [id], onDelete: Cascade)

  officerId String
  officer   Officer @relation(fields: [officerId], references: [id], onDelete: Restrict)

  departmentId String @db.VarChar(64)
  squadId      String? @db.VarChar(64)

  @@unique([patrolMinuteId, officerId], map: "uq_patrol_officer")
  @@index([officerId], map: "idx_patrol_officer_officer_btree")
  @@map("patrol_minute_officers")
}

model RecoveredObject {
  id          String   @id @default(cuid())
  description String   @db.VarChar(300)
  quantity    Int      @default(1)
  unit        String?  @db.VarChar(40)
  photoUrl    String?  @db.VarChar(2048)
  registeredAt DateTime @default(now())

  patrolMinuteId String?
  patrolMinute   PatrolMinute? @relation(fields: [patrolMinuteId], references: [id], onDelete: SetNull)

  incidentId String?

  @@index([patrolMinuteId], map: "idx_recovered_patrol_btree")
  @@map("recovered_objects")
}

// ─────────────────────────────────────────────────────────────────────────────
// DETENIDOS Y CALABOZOS
// ─────────────────────────────────────────────────────────────────────────────

model Detainee {
  id         String         @id @default(cuid())
  cedula     String?        @db.VarChar(20)
  nombres    String         @db.VarChar(80)
  apellidos  String         @db.VarChar(80)
  alias      String?        @db.VarChar(80)
  cellNumber String?        @db.VarChar(20)
  status     DetaineeStatus @default(EN_CALABOZO)
  ingresoAt  DateTime       @default(now())
  egresoAt   DateTime?
  notas      String?        @db.Text
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  hearings DetaineeHearing[]
  records  DetaineeRecord[]

  @@index([cedula], map: "idx_detainee_cedula_btree")
  @@index([status], map: "idx_detainee_status_btree")
  @@map("detainees")
}

model DetaineeHearing {
  id            String   @id @default(cuid())
  fecha         DateTime
  tribunal      String   @db.VarChar(120)
  resultado     String?  @db.VarChar(200)
  observaciones String?  @db.Text
  createdAt     DateTime @default(now())

  detaineeId String
  detainee   Detainee @relation(fields: [detaineeId], references: [id], onDelete: Cascade)

  @@index([detaineeId], map: "idx_hearing_detainee_btree")
  @@index([fecha], map: "idx_hearing_fecha_btree")
  @@map("detainee_hearings")
}

model DetaineeRecord {
  id            String   @id @default(cuid())
  delito        String   @db.VarChar(120)
  fecha         DateTime @default(now())
  observaciones String?  @db.Text

  detaineeId String
  detainee   Detainee @relation(fields: [detaineeId], references: [id], onDelete: Cascade)

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  officerId  String?
  officer    Officer? @relation(fields: [officerId], references: [id], onDelete: SetNull)

  @@index([detaineeId], map: "idx_detainee_record_detainee_btree")
  @@map("detainee_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// GUARDIAS Y PRESENCIA OPERATIVA
// ─────────────────────────────────────────────────────────────────────────────

model OfficerShift {
  id          String      @id @default(cuid())
  fecha       DateTime    @db.Date
  horaInicio  String      @db.VarChar(5)
  horaFin     String      @db.VarChar(5)
  status      ShiftStatus @default(ON_DUTY_PENDING)
  checkedInAt DateTime?
  checkInLatitude  Float?
  checkInLongitude Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  officerId String
  officer   Officer @relation(fields: [officerId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@index([fecha], map: "idx_shift_fecha_btree")
  @@index([officerId, fecha], map: "idx_shift_officer_fecha_btree")
  @@index([departmentId, fecha], map: "idx_shift_dept_fecha_btree")
  @@map("officer_shifts")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOGÍSTICA E INVENTARIO
// ─────────────────────────────────────────────────────────────────────────────

model InventoryAsset {
  id           String      @id @default(cuid())
  code         String      @unique @db.VarChar(32)
  name         String      @db.VarChar(120)
  assetType    AssetType
  serialNumber String?     @db.VarChar(64)
  status       AssetStatus @default(OPERATIVO)
  notas        String?     @db.Text
  turno        String?     @db.VarChar(20)
  assignedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  assignedOfficerId String?
  assignedOfficer   Officer? @relation("InventoryAssignee", fields: [assignedOfficerId], references: [id], onDelete: SetNull)

  @@index([assetType], map: "idx_inventory_type_btree")
  @@index([departmentId], map: "idx_inventory_dept_btree")
  @@index([assignedOfficerId], map: "idx_inventory_officer_btree")
  @@index([turno], map: "idx_inventory_turno_btree")
  @@map("inventory_assets")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARQUE DE ARMAS
// ─────────────────────────────────────────────────────────────────────────────

model Weapon {
  id           String       @id @default(cuid())
  serialNumber String       @unique @db.VarChar(64)
  tipo         String       @db.VarChar(60)
  marca        String?      @db.VarChar(60)
  modelo       String?      @db.VarChar(60)
  status       WeaponStatus @default(DISPONIBLE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  assignments WeaponAssignment[]

  @@index([status], map: "idx_weapon_status_btree")
  @@map("weapons")
}

model WeaponAssignment {
  id            String    @id @default(cuid())
  assignedAt    DateTime  @default(now())
  returnedAt    DateTime?
  turno         String?   @db.VarChar(40)
  observaciones String?   @db.Text

  weaponId String
  weapon   Weapon @relation(fields: [weaponId], references: [id], onDelete: Restrict)

  officerId String
  officer   Officer @relation("WeaponAssignee", fields: [officerId], references: [id], onDelete: Restrict)

  assignedByOfficerId String
  assignedByOfficer   Officer @relation("WeaponAssigner", fields: [assignedByOfficerId], references: [id], onDelete: Restrict)

  @@index([weaponId], map: "idx_weapon_assign_weapon_btree")
  @@index([officerId], map: "idx_weapon_assign_officer_btree")
  @@map("weapon_assignments")
}
