# ─────────────────────────────────────────────────────────────────────────────
# Polisur SITOP / DAET — Variables de entorno (Docker Compose)
# Copie este archivo como '.env' en la raíz del monorepo antes de desplegar.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (polisur-db) ──────────────────────────────────────────────────
POSTGRES_USER=polisur
POSTGRES_PASSWORD=cambiar-por-contrasena-segura
POSTGRES_DB=polisur
POSTGRES_PORT=5432

# ── API NestJS (polisur-api) ─────────────────────────────────────────────────
# URL interna de Docker Compose (hostname = nombre del servicio)
DATABASE_URL=postgresql://polisur:cambiar-por-contrasena-segura@polisur-db:5432/polisur?schema=public

# Secreto JWT (mínimo 32 caracteres). NUNCA reutilizar en producción.
JWT_SECRET=reemplazar-por-secreto-aleatorio-de-al-menos-32-caracteres

# Puerto expuesto de la API en el host
PORT=3001
API_PORT=3001

# Origen permitido para CORS (URL pública del frontend)
CORS_ORIGIN=http://localhost:3000

# URL pública de la API (usada en URLs de evidencias)
API_PUBLIC_URL=http://localhost:3001

# Directorio persistente para fotos de evidencia (cadena de custodia)
# Render: montar disco en /var/data y usar /var/data/evidence
EVIDENCE_STORAGE_DIR=./uploads/evidence

# ── GitHub Actions (CI/CD) ───────────────────────────────────────────────────
# Ver README.md — Secretos: REGISTRY_USERNAME, REGISTRY_PASSWORD, NEXT_PUBLIC_API_URL

# ── Frontend Next.js (polisur-frontend) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
FRONTEND_PORT=3000
